<Window x:Class="ProjektBazyDanych.WyszukiwanieProduktów"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ProjektBazyDanych"
        mc:Ignorable="d"
        Title="WyszukiwanieProduktów" Height="450" Width="800">
    <Grid Margin="10">
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#E3F2FD" Offset="0"/>
                <GradientStop Color="White" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <!-- Sekcja filtrów -->
        <GroupBox Header="Filtruj wyniki" Margin="20,20,400,100" FontWeight="Bold" Foreground="#0D47A1">
            <StackPanel Margin="10,0,10,0" Height="265">
                <Label Content="Cena od:" Foreground="#0D47A1"/>
                <TextBox x:Name="TbOD" Width="140" Height="25" Background="White" BorderBrush="#2196F3" Foreground="Black"/>

                <Label Content="Cena do:" Margin="0,10,0,0" Foreground="#0D47A1"/>
                <TextBox x:Name="TbDO" Width="140" Height="25" Background="White" BorderBrush="#2196F3" Foreground="Black"/>

                <Label Content="Kategoria:" Margin="0,10,0,0" Foreground="#0D47A1"/>
                <ComboBox x:Name="CbKategoria" SelectedValuePath="Tag" Width="160" Height="30" Foreground="#0D47A1" BorderBrush="#2196F3" Margin="0,5,0,0">
                    <ComboBox.Background>
                        <LinearGradientBrush EndPoint="0,1">
                            <GradientStop Color="#FFF0F0F0"/>
                            <GradientStop Color="#FFE3F2FD" Offset="1"/>
                        </LinearGradientBrush>
                    </ComboBox.Background>
                    <ComboBoxItem Content="Płyty główne" Tag="1" />
                    <ComboBoxItem Content="Dyski HDD" Tag="2" />
                    <ComboBoxItem Content="Dyski SSD" Tag="3" />
                    <ComboBoxItem Content="Pamięć RAM" Tag="4" />
                    <ComboBoxItem Content="Procesory" Tag="5" />
                    <ComboBoxItem Content="Zasilacze" Tag="6" />
                </ComboBox>

                <Button x:Name="BtnWyszukaj" Content="Wyszukaj" Width="140" Height="40" Margin="0,15,0,0"
                        Background="#64B5F6" Foreground="White" Click="BtnWyszukaj_Click"/>
            </StackPanel>
        </GroupBox>

        <!-- Lista wyników -->
        <GroupBox Header="Wyniki wyszukiwania" Margin="380,20,10,100" FontWeight="Bold" Foreground="#0D47A1">
            <ListBox x:Name="LbWyszukaneProdukty" Background="#E1F5FE" BorderBrush="#2196F3"/>
        </GroupBox>

        <!-- Przycisk powrotu -->
        <Button x:Name="btnPowrót" Content="Wróć" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,20"
                Height="44" Width="150" Background="#BBDEFB" Foreground="Black" Click="btnPowrót_Click"/>
    </Grid>
</Window>
